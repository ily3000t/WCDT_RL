<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <input>
        <net-file value="highway_merge.net.xml"/>
        <route-files value="highway_merge.rou.xml"/>
    </input>

    <time>
        <begin value="0"/>
        <end value="3600"/>
        <step-length value="0.1"/>
    </time>

    <processing>
        <collision.action value="warn"/>
        <lanechange.duration value="1.0"/>
    </processing>

    <report>
        <verbose value="false"/>
        <no-step-log value="true"/>
    </report>
</configuration>
